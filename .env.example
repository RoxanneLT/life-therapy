# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Life-Therapy

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxx

# Vercel Cron (for booking reminders)
CRON_SECRET=your-cron-secret-here

# Bunny.net CDN (Storage Zone — worksheets & downloadable files)
BUNNY_STORAGE_ZONE_NAME=life-therapy-files
BUNNY_STORAGE_API_KEY=your-storage-api-key
BUNNY_STORAGE_REGION=de
# Your Pull Zone hostname (e.g. life-therapy-cdn.b-cdn.net or cdn.life-therapy.co.za)
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=life-therapy-cdn.b-cdn.net

# Bunny.net Stream (course videos)
BUNNY_STREAM_LIBRARY_ID=your-library-id
BUNNY_STREAM_API_KEY=your-stream-api-key
